---
interface PersonalProject {
  title: string;
  description?: string;
  link: string;
  preview: string;
  status: string;
}

const personalProjects: PersonalProject[] = [
  {
    title: "TailorDost",
    description: "Run your boutique without the paperwork. Capture customer measurements, track fabric and design references, monitor stitching progress, and manage payments — all in one place, built specifically for boutique owners.",
    link: "https://tailordost.in/",
    preview: "https://tailordost.in/",
    status: "Live",
  },
  {
    title: "BuildTrackr",
    description: "Track workers, materials, machinery, and financials across all your construction sites. Real-time progress monitoring, expense tracking, and comprehensive reporting — with role-based access control built for teams of any size.",
    link: "https://buildtrackr.com/",
    preview: "https://buildtrackr.com/",
    status: "Live",
  },
  {
    title: "PBXly",
    description: "A cloud-based PBX that streamlines business communication with call management, voicemail, and unified communications. Built for small businesses, enterprises, remote teams, and call centers — any team that takes communication seriously.",
    link: "https://pbxly.com/",
    preview: "https://pbxly.com/",
    status: "Live",
  },
  {
    title: "The Travel Diary",
    description: "Genuine, unfiltered travel experiences from around the world. Honest reviews, practical planning tips, and real-life insights to help fellow travelers make informed decisions.",
    link: "https://travel.vjworks.com",
    preview: "https://travel.vjworks.com",
    status: "In Development",
  },
];

const professionalHighlights = [
  {
    title: "Mojaloop Testing Toolkit",
    description:
      "Open-source toolkit enabling Digital Financial Service Providers (DFSPs) to test their Mojaloop implementations. Served as workstream owner, led the team, and contributed in NodeJS & ReactJS.",
    link: "https://github.com/mojaloop/ml-testing-toolkit",
    tags: ["Node.js", "React", "Open Source", "Fintech"],
  },
  {
    title: "COMESA DRPP Payment Switch",
    description:
      "Major contributor to the COMESA Digital Retail Payment Platform — a Mojaloop-based multi-scheme interoperable payment switch serving member states across eastern and southern Africa. Implemented ISO 20022 message transformation, cross-currency FX transfers, and interscheme proxy functionality.",
    link: "https://mojaloop.io/",
    tags: ["Mojaloop", "ISO 20022", "FX", "Kafka", "Kubernetes", "Node.js"],
  },
  {
    title: "Mojaloop Batch Processing",
    description:
      "Redesigned and implemented batch processing in Mojaloop using advanced Kafka partitioning and assignment strategies. Achieved massive performance gains. Presented to the Mojaloop community design authority and got it approved.",
    link: "https://mojaloop.io/",
    tags: ["Kafka", "Node.js", "Performance", "Architecture"],
  },
  {
    title: "Reliable Calling",
    description:
      "Built the entire calling card platform solo in under a month — the only developer in the company at the time. Handled everything from Asterisk AGI scripts and IVR to the web CRM. It launched, it worked, and it made money.",
    link: "#",
    tags: ["Asterisk", "PHP", "MySQL", "VoIP", "Solo Build"],
  },
  {
    title: "ILD Softswitch",
    description:
      "Designed and built the web interface and load balancing logic for an international long-distance softswitch routing calls between India and the USA through VPN tunnels — engineered to handle 20,000 concurrent calls. One of only 10 ILD-licensed entities in India at the time.",
    link: "#",
    tags: ["VoIP", "SIP", "Kamailio", "Asterisk", "VPN", "PHP"],
  },
];
---

<section
  id="experiment"
  class="py-12 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">The experiments</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">
      Things I've Built (Some Actually Finished)
    </h3>

    <!-- Professional Highlights -->
    <h4 class="text-xl font-semibold text-[var(--white-icon)] mb-4">Professional Work</h4>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      {
        professionalHighlights.map((project) => (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group p-6 rounded-2xl border border-[var(--white-icon-tr)] bg-[#1414149c] hover:bg-[var(--white-icon-tr)] transition-all duration-300 flex flex-col gap-3"
          >
            <div class="flex items-start justify-between gap-2">
              <h5 class="text-lg font-semibold group-hover:text-white transition-colors">{project.title}</h5>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 flex-shrink-0 text-[var(--white-icon)] group-hover:text-white transition-colors mt-1">
                <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
              </svg>
            </div>
            <p class="text-[var(--white-icon)] text-sm leading-relaxed flex-grow">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2 mt-auto">
              {project.tags.map((tag) => (
                <span class="text-xs px-2 py-1 rounded-full border border-[var(--white-icon-tr)] text-[var(--white-icon)] bg-[#ffffff08]">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>

    <!-- Personal Projects -->
    <h4 class="text-xl font-semibold text-[var(--white-icon)] mb-4">Personal Projects</h4>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        personalProjects.map((project) => (
          <div class="group">
            <a
              href={project.preview}
              target="_blank"
              rel="noopener noreferrer"
              class="block"
            >
              <div class="flex items-center px-3">
                <div class="flex-grow">
                  <h4 class="text-2xl font-semibold">{project.title}</h4>
                  <span class="py-1 text-sm text-[var(--white-icon)]">
                    {project.status}
                  </span>
                  {project.description && (
                    <p class="mt-2 text-sm text-[var(--white-icon)] leading-relaxed">{project.description}</p>
                  )}
                </div>
                <div class="flex gap-2 ml-auto">
                  <a
                    target="_blank"
                    href={project.preview}
                    aria-label="Preview"
                    class="size-14 flex justify-center items-center text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-3 rounded-xl bg-[#1414149c] hover:bg-[var(--white-icon-tr)]"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="size-7"
                    >
                      <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
                    </svg>
                  </a>
                </div>
              </div>
            </a>
          </div>
        ))
      }
    </div>

    <a
      target="_blank"
      href="https://github.com/vijayg10?tab=repositories"
      aria-label="GitHub"
      class="w-full flex items-center justify-center gap-2 mt-9 text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-3 rounded-full bg-[#1414149c] hover:bg-[var(--white-icon-tr)] hover:scale-105"
    >
      <span class="md:text-lg text-md">More projects (and some abandoned ones) on</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-6"
      >
        <path
          d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"
        ></path>
      </svg>
    </a>
  </div>
</section>
