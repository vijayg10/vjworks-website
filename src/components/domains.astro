---

<section
  id="domains"
  class="py-12 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">The breadth</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-4">
      Domains I've Actually Shipped In
    </h3>
    <p class="text-[var(--white-icon)] mb-8 text-lg">
      Twenty years across four very different industries. Not because I planned it that way — I just kept saying yes to interesting problems.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        domains.map((domain) => (
          <div class="p-6 rounded-2xl border border-[var(--white-icon-tr)] bg-[#1414149c] hover:bg-[var(--white-icon-tr)] transition-all duration-300 flex flex-col gap-4">
            <div class="flex items-center gap-3">
              <span class="text-3xl">{domain.icon}</span>
              <div>
                <h4 class="text-xl font-semibold">{domain.title}</h4>
                <span class="text-sm text-[var(--white-icon)] opacity-60">{domain.years}</span>
              </div>
            </div>
            <p class="text-[var(--white-icon)] text-sm leading-relaxed">
              {domain.description}
            </p>
            <div class="flex flex-wrap gap-2 mt-auto">
              {domain.tags.map((tag) => (
                <span class="text-xs px-2 py-1 rounded-full border border-[var(--white-icon-tr)] text-[var(--white-icon)] bg-[#ffffff08]">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
