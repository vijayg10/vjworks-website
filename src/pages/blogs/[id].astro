---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav.astro";
import Footer from "@/components/footer.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export async function getStaticPaths() {
  const blogPosts = await getCollection("blog", ({ id }) => id.startsWith("en/"));

  return blogPosts.map((post) => {
    const idWithoutLang = post.id.replace(/^en\//, "");
    return {
      params: { id: idWithoutLang },
      props: { post },
    };
  });
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await render(post);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", { year: "numeric", month: "short", day: "2-digit" }).format(date);

const allPosts = await getCollection("blog", ({ id }) => id.startsWith("en/"));
const relatedPosts = allPosts
  .filter((entry) => entry.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const slugFromId = (id: string) => id.replace(/^en\//, "");
---

<Layout title={`${post.data.title} | vjworks`} description={post.data.description} ogTitle={`${post.data.title} | Blogs | vjworks`}>
  <Nav />
  <main class="mx-auto max-w-3xl pb-10 pt-28 md:pt-32">
    <a href="/blogs" class="text-sm text-[--white-icon] hover:text-[--white]">← Back to blogs</a>

    <header class="mt-6">
      <h1 class="text-3xl font-semibold text-[--white]">{post.data.title}</h1>
      <p class="mt-3 text-[--white-icon]">{post.data.description}</p>

      <div class="mt-6 flex items-center gap-4">
        <Image
          class="h-12 w-12 rounded-full object-cover"
          src={post.data.authorImage as unknown as ImageMetadata}
          alt={post.data.authorImageAlt}
          format="avif"
          draggable={false}
        />
        <div>
          <p class="text-sm font-medium text-[--white]">{post.data.author}</p>
          <p class="text-xs text-[--white-icon]">
            {formatDate(post.data.pubDate)} • {post.data.readTime} min read
          </p>
        </div>
      </div>

      <div class="mt-6">
        <Image
          class="w-full rounded-2xl object-cover"
          src={post.data.cardImage as unknown as ImageMetadata}
          alt={post.data.cardImageAlt}
          format="avif"
          draggable={false}
        />
      </div>

      {post.data.tags?.length ? (
        <div class="mt-6 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="rounded-lg bg-white/10 px-3 py-1 text-xs text-[--white]">{tag}</span>
          ))}
        </div>
      ) : null}
    </header>

    <article class="mt-10 text-[--white] leading-relaxed">
      <Content />
    </article>

    {relatedPosts.length ? (
      <section class="mt-14">
        <h2 class="text-xl font-semibold text-[--white]">Related posts</h2>
        <div class="mt-5 grid gap-6 md:grid-cols-2">
          {relatedPosts.map((entry) => (
            <a
              href={`/blogs/${slugFromId(entry.id)}`}
              class="block overflow-hidden rounded-2xl border border-white/10 bg-white/5"
            >
              <Image
                class="h-40 w-full object-cover"
                src={entry.data.cardImage as unknown as ImageMetadata}
                alt={entry.data.cardImageAlt}
                format="avif"
                draggable={false}
              />
              <div class="p-5">
                <p class="text-xs text-[--white-icon]">{formatDate(entry.data.pubDate)}</p>
                <p class="mt-2 text-base font-semibold text-[--white]">{entry.data.title}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ) : null}
  </main>
  <Footer />
</Layout>

<style is:global>
  /* Markdown typography (explicit because global reset removes defaults) */
  article h2,
  article h3,
  article h4,
  article h5,
  article h6 {
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  article h2 {
    font-size: 1.5rem;
    line-height: 2rem;
  }

  article h3 {
    font-size: 1.25rem;
    line-height: 1.75rem;
  }

  article h4 {
    font-size: 1.125rem;
    line-height: 1.75rem;
  }

  article p {
    margin-top: 1.5rem;
  }

  article ul,
  article ol {
    margin-top: 1.5rem;
    padding-left: 1.5rem;
  }

  article ul {
    list-style-type: disc;
  }

  article ol {
    list-style-type: decimal;
  }

  article li {
    margin-top: 0.5rem;
  }

  article a {
    color: var(--sec);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  article strong {
    font-weight: 600;
  }

  article em {
    font-style: italic;
  }

  article code {
    background-color: var(--white-icon-tr);
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Consolas, "Liberation Mono", Menlo, monospace;
  }

  article pre {
    overflow: auto;
    margin-top: 1.5rem;
    padding: 1rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background-color: var(--white-icon-tr);
  }

  article pre code {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
    font-size: 0.875rem;
  }
</style>
