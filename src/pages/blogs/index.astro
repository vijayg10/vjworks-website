---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav.astro";
import Footer from "@/components/footer.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const englishBlogEntries = await getCollection("blog", ({ id }) => id.startsWith("en/"));

const blogPosts: CollectionEntry<"blog">[] = englishBlogEntries.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const mostRecentPost = blogPosts[0];
const otherPosts = blogPosts.slice(1);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", { year: "numeric", month: "short", day: "2-digit" }).format(date);

const slugFromId = (id: string) => id.replace(/^en\//, "");
---

<Layout
  title="Blogs | vjworks"
  description="Essays and notes on software development, architecture, and fundamentals."
  ogTitle="Blogs | vjworks"
>
  <Nav />
  <main class="mx-auto max-w-5xl pb-10 pt-28 md:pt-32">
    <header class="mb-10">
      <h1 class="text-4xl font-semibold text-[--white]">Blogs</h1>
      <p class="mt-2 text-[--white-icon]">
        Essays and notes on software development, architecture, and fundamentals.
      </p>
    </header>

    {mostRecentPost ? (
      <section class="mb-10">
        <a
          href={`/blogs/${slugFromId(mostRecentPost.id)}`}
          class="block overflow-hidden rounded-2xl border border-white/10 bg-white/5"
        >
          <div class="grid gap-6 md:grid-cols-[1.2fr_1fr]">
            <div class="p-6">
              <p class="text-xs tracking-wide text-[--white-icon]">Most recent</p>
              <h2 class="mt-2 text-2xl font-semibold text-[--white]">{mostRecentPost.data.title}</h2>
              <p class="mt-3 text-[--white-icon]">{mostRecentPost.data.description}</p>

              <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-[--white-icon]">
                <span>{mostRecentPost.data.author}</span>
                <span class="opacity-60">•</span>
                <span>{formatDate(mostRecentPost.data.pubDate)}</span>
                <span class="opacity-60">•</span>
                <span>{mostRecentPost.data.readTime} min read</span>
              </div>
            </div>

            <div class="p-6 md:pl-0">
              <Image
                class="h-56 w-full rounded-xl object-cover"
                src={mostRecentPost.data.cardImage as unknown as ImageMetadata}
                alt={mostRecentPost.data.cardImageAlt}
                format="avif"
                draggable={false}
              />
            </div>
          </div>
        </a>
      </section>
    ) : null}

    <section>
      <div class="grid gap-6 md:grid-cols-2">
        {otherPosts.map((post) => (
          <a
            href={`/blogs/${slugFromId(post.id)}`}
            class="block overflow-hidden rounded-2xl border border-white/10 bg-white/5"
          >
            <Image
              class="h-44 w-full object-cover"
              src={post.data.cardImage as unknown as ImageMetadata}
              alt={post.data.cardImageAlt}
              format="avif"
              draggable={false}
            />
            <div class="p-5">
              <h3 class="text-lg font-semibold text-[--white]">{post.data.title}</h3>
              <p class="mt-2 text-sm text-[--white-icon]">{post.data.description}</p>
              <p class="mt-4 text-xs text-[--white-icon]">
                {formatDate(post.data.pubDate)} • {post.data.readTime} min read
              </p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
